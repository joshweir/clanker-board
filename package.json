{
  "name": "clanker-board",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "seed": "pnpm --filter @clanker/api seed",
    "start": "pnpm --filter @clanker/web build:app && NODE_ENV=production pnpm --filter @clanker/api start",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter @clanker/web test:e2e",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-all": "./scripts/check-all.sh",
    "audit-ci": "pnpm audit --audit-level=high",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^22.20.1",
    "@vitest/coverage-v8": "4.1.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.24.0",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,css,md,yml,yaml}": "prettier --write"
  }
}
